<Window x:Class="NonlinearSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Розв'язання систем нелінійних рівнянь" 
        Height="850" Width="1300"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgPrimary" Color="#0D1117"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#161B22"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#21262D"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F0883E"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#BC8CFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2EA043"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A7F37"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#CDD9E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444C56"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363D"/>
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#21262D"/>
            <Setter Property="RowBackground" Value="#0D1117"/>
            <Setter Property="AlternatingRowBackground" Value="#161B22"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#161B22"/>
                        <Setter Property="Foreground" Value="#58A6FF"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderBrush" Value="#30363D"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Logo -->
                    <Border Width="32" Height="32" CornerRadius="8" Background="#1F6FEB" Margin="0,0,12,0">
                        <TextBlock Text="∫" FontSize="18" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NonlinearSolver" FontSize="16" FontWeight="SemiBold" 
                               Foreground="#E6EDF3" VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="#444C56" VerticalAlignment="Center" FontSize="16"/>
                    <TextBlock Text="Лаб. робота №3" Foreground="#8B949E" 
                               VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="12" Background="#1F6FEB22" BorderBrush="#1F6FEB44" BorderThickness="1" Padding="10,4">
                        <TextBlock Text="Метод Ньютона / Зейделя / Простої ітерації" 
                                   Foreground="#58A6FF" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                        <Style TargetType="Grid">
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                        <Style TargetType="Button">
                            <Setter Property="Margin" Value="0,0,0,0"/>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Variant Selection -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="ВАРІАНТ ЗАВДАННЯ" Style="{StaticResource FieldLabel}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ВАРІАНТ" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="VariantComboBox" Style="{StaticResource DarkComboBox}"
                                              SelectionChanged="VariantComboBox_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="МЕТОД" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="MethodLabel" Text="—" Foreground="#58A6FF" 
                                               FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Height="32"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- System Display -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="СИСТЕМА РІВНЯНЬ" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                            <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" 
                                    CornerRadius="6" Padding="12">
                                <TextBlock x:Name="SystemDisplay" 
                                           Foreground="#E6EDF3" FontFamily="Consolas" FontSize="13"
                                           TextWrapping="Wrap" LineHeight="22"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Custom Equations -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="ВЛАСНІ РІВНЯННЯ" Style="{StaticResource FieldLabel}" 
                                           VerticalAlignment="Center" Margin="0"/>
                                <Border CornerRadius="4" Background="#BC8CFF22" BorderBrush="#BC8CFF44" 
                                        BorderThickness="1" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="custom" Foreground="#BC8CFF" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Рівняння 1 (f₁)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="Eq1TextBox" Style="{StaticResource DarkTextBox}"
                                     Text="x^2 - 2*x - y + 0.5" Margin="0,0,0,8"/>
                            <TextBlock Text="Рівняння 2 (f₂)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="Eq2TextBox" Style="{StaticResource DarkTextBox}"
                                     Text="x^2 + 4*y^2 - 4" Margin="0,0,0,8"/>
                            <TextBlock Text="Рівняння 3 (f₃, необов'язково)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="Eq3TextBox" Style="{StaticResource DarkTextBox}"
                                     Text="" Margin="0,0,0,8"/>
                            
                            <Border Background="#161B22" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                    BorderBrush="#30363D" BorderThickness="1">
                                <TextBlock Foreground="#8B949E" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap">
                                    <Run Text="Підтримується: +, -, *, /, ^, sin(), cos(), tan(), log(), sqrt(), exp()"/>
                                </TextBlock>
                            </Border>
                            
                            <TextBlock Text="МЕТОД (власні рівняння)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CustomMethodComboBox" Style="{StaticResource DarkComboBox}" Margin="0,0,0,0">
                                <ComboBoxItem Content="Метод Ньютона" IsSelected="True"/>
                                <ComboBoxItem Content="Метод Зейделя"/>
                                <ComboBoxItem Content="Метод простої ітерації"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Parameters -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="ПАРАМЕТРИ" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="X₀ (початкове)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="X0TextBox" Style="{StaticResource DarkTextBox}" Text="2.0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Y₀ (початкове)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="Y0TextBox" Style="{StaticResource DarkTextBox}" Text="0.25"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Z₀ (для 3 рівн.)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="Z0TextBox" Style="{StaticResource DarkTextBox}" Text="0.0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="ТОЧНІСТЬ (ε)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="EpsTextBox" Style="{StaticResource DarkTextBox}" Text="0.0001"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="МАКС. ІТЕРАЦІЙ" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="MaxIterTextBox" Style="{StaticResource DarkTextBox}" Text="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="▶  Розв'язати (варіант)" 
                                Style="{StaticResource PrimaryButton}"
                                Click="SolveVariant_Click" Height="38"/>
                        <Button Grid.Column="2" Content="✎  Власні рівняння" 
                                Style="{StaticResource SecondaryButton}"
                                Click="SolveCustom_Click" Height="38"/>
                    </Grid>

                    <Button Content="⟳  Очистити результати" Style="{StaticResource SecondaryButton}"
                            Click="Clear_Click" Height="34"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#30363D" ResizeBehavior="PreviousAndNext"/>

            <!-- Right Panel -->
            <Grid Grid.Column="2" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- Status Bar -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="РЕЗУЛЬТАТ" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="StatusLabel" Text="Очікування розрахунку..." 
                                       Foreground="#8B949E" FontSize="13"/>
                        </StackPanel>

                        <Border Grid.Column="1" CornerRadius="6" Padding="12,6" Margin="8,0"
                                Background="#0D1117" BorderBrush="#30363D" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ІТЕРАЦІЇ" Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock x:Name="IterCountLabel" Text="—" Foreground="#F0883E" 
                                           FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" CornerRadius="6" Padding="12,6" Margin="0,0,8,0"
                                Background="#0D1117" BorderBrush="#30363D" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ПОХИБКА" Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock x:Name="ErrorLabel" Text="—" Foreground="#3FB950" 
                                           FontSize="14" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" CornerRadius="6" Padding="12,6"
                                Background="#0D1117" BorderBrush="#30363D" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="МЕТОД" Style="{StaticResource FieldLabel}" Margin="0"/>
                                <TextBlock x:Name="UsedMethodLabel" Text="—" Foreground="#BC8CFF" 
                                           FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Iterations Table -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ТАБЛИЦЯ ІТЕРАЦІЙ" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" x:Name="IterationsGrid"
                                  Style="{StaticResource DarkDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ітерація" Binding="{Binding Iteration}" Width="70"/>
                                <DataGridTextColumn Header="x₁" Binding="{Binding X1}" Width="*"/>
                                <DataGridTextColumn Header="x₂" Binding="{Binding X2}" Width="*"/>
                                <DataGridTextColumn Header="x₃" Binding="{Binding X3}" Width="*"/>
                                <DataGridTextColumn Header="|Δx₁|" Binding="{Binding DeltaX1}" Width="*"/>
                                <DataGridTextColumn Header="|Δx₂|" Binding="{Binding DeltaX2}" Width="*"/>
                                <DataGridTextColumn Header="|Δx₃|" Binding="{Binding DeltaX3}" Width="*"/>
                                <DataGridTextColumn Header="||F(P)||" Binding="{Binding FNorm}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Log -->
                <Border Grid.Row="3" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="ЛОГ ВИКОНАННЯ" Style="{StaticResource FieldLabel}" 
                                       VerticalAlignment="Center" Margin="0"/>
                            <Button Content="Очистити" Style="{StaticResource SecondaryButton}"
                                    Padding="8,3" FontSize="11" Margin="10,0,0,0"
                                    Click="ClearLog_Click"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogTextBox" 
                                     Background="Transparent" Foreground="#8B949E"
                                     BorderThickness="0" IsReadOnly="True"
                                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                     AcceptsReturn="True"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
