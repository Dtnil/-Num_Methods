<Window x:Class="Lab5_Variant10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторна №5 | Варіант 9 — Чисельне інтегрування (Трапеції)"
        Height="780" Width="1100"
        MinHeight="700" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="2" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="AccentValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#58A6FF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="#58A6FF"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ч И С Е Л Ь Н Е   І Н Т Е Г Р У В А Н Н Я" FontFamily="Consolas" FontSize="11"
                               Foreground="#58A6FF" FontWeight="Bold"/>
                    <TextBlock Text="Варіант 9 · Метод Трапецій" FontFamily="Consolas" FontSize="22"
                               Foreground="#E6EDF3" FontWeight="Bold" Margin="0,2,0,0"/>
                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#8B949E" Margin="0,3,0,0">
                        <Run>u(x) = 3 + sin(2x) / 2</Run>
                        <Run Foreground="#3FB950">  ∫₀⁵ u(i) di</Run>
                        <Run Foreground="#8B949E">  → Потужність двигуна</Run>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1" Background="#1F2937" CornerRadius="8" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="ЛАБОРАТОРНА РОБОТА №5" FontFamily="Consolas"
                                   FontSize="10" Foreground="#6E7681" HorizontalAlignment="Center"/>
                        <TextBlock Text="Чисельні методи в інформатиці" FontFamily="Consolas"
                                   FontSize="10" Foreground="#6E7681" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <ScrollViewer Grid.Column="0"
                          Margin="0,0,12,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>

                    <!-- Formula Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ФОРМУЛА ТРАПЕЦІЙ" FontFamily="Consolas" FontSize="10"
                                   Foreground="#58A6FF" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Border Background="#0D1117" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#3FB950"
                                       TextWrapping="Wrap" LineHeight="20">
                                <Run>∫f(x)dx ≈ h·[(f₀ + fₙ)/2 + Σf(xᵢ)]</Run>
                            </TextBlock>
                        </Border>

                        <Border Background="#0D1117" CornerRadius="8" Padding="12">
                            <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#C9D1D9"
                                       TextWrapping="Wrap" LineHeight="18">

                                <Run Foreground="#8B949E">Складна формула трапецій:</Run>
                                <LineBreak/>
                                <Run>T(f,h) = h·[(f(a)+f(b))/2 + Σf(xᵢ)]</Run>
                                <LineBreak/>
                                <LineBreak/>
                                <Run Foreground="#8B949E">Похибка: O(h²)</Run>
                                <LineBreak/>
                                <Run Foreground="#8B949E">E = -(b-a)·h²·f''(ξ)/12</Run>

                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Parameters Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ПАРАМЕТРИ" FontFamily="Consolas" FontSize="10"
                                   Foreground="#58A6FF" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="i₀ (нижня межа)" Style="{StaticResource LabelStyle}" Margin="0,0,0,3"/>
                                <TextBlock Text="0" Style="{StaticResource ValueStyle}" Foreground="#3FB950"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="iₖ (верхня межа)" Style="{StaticResource LabelStyle}" Margin="0,0,0,3"/>
                                <TextBlock Text="5" Style="{StaticResource ValueStyle}" Foreground="#3FB950"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="#30363D" Margin="0,8"/>

                        <TextBlock Text="Кількість підінтервалів (n)" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtN" Text="14" Style="{StaticResource ValueStyle}"
                                   Foreground="#F0883E" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <Slider x:Name="sliderN" Minimum="7" Maximum="100" Value="14"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="sliderN_ValueChanged"/>

                        <Separator Background="#30363D" Margin="0,10"/>

                        <TextBlock Text="Крок h = (b-a)/n" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtH" Text="h = 0.357143" Style="{StaticResource ValueStyle}" Foreground="#D2A8FF"/>
                    </StackPanel>
                </Border>

                <!-- Result Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="РЕЗУЛЬТАТ" FontFamily="Consolas" FontSize="10"
                                   Foreground="#58A6FF" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="Чисельний інтеграл (Трапецій):" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtResult" Text="..." Style="{StaticResource AccentValue}" Margin="0,0,0,10"/>

                        <Separator Background="#30363D" Margin="0,0,0,10"/>

                        <TextBlock Text="Аналітичний результат:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtAnalytical" Text="..." FontFamily="Consolas"
                                   FontSize="16" FontWeight="Bold" Foreground="#3FB950"/>

                        <Separator Background="#30363D" Margin="0,10"/>

                        <TextBlock Text="Абсолютна похибка:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtError" Text="..." FontFamily="Consolas"
                                   FontSize="14" FontWeight="Bold" Foreground="#F85149"/>
                    </StackPanel>
                </Border>

                <!-- Node Count Info -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="ВУЗЛОВІ ТОЧКИ" FontFamily="Consolas" FontSize="10"
                                   Foreground="#58A6FF" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtNodeInfo" Text="" FontFamily="Consolas"
                                   FontSize="11" Foreground="#8B949E" TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>
                </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel: Chart -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#1F2937" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="20" Height="3" Fill="#58A6FF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="u(x) = 3 + sin(2x)/2" FontFamily="Consolas" FontSize="11" Foreground="#C9D1D9"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1F2937" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="12" Height="12" Fill="#3FB95055" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Площа (∫)" FontFamily="Consolas" FontSize="11" Foreground="#C9D1D9"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1F2937" CornerRadius="6" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="12" Fill="#F0883E55" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Трапеції" FontFamily="Consolas" FontSize="11" Foreground="#C9D1D9"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Canvas x:Name="chartCanvas" Grid.Row="1" ClipToBounds="True"
                            Background="#0D1117" SizeChanged="chartCanvas_SizeChanged"/>

                    <!-- X axis label -->
                    <TextBlock Grid.Row="2" Text="Струм i (А)" FontFamily="Consolas" FontSize="11"
                               Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#161B22" CornerRadius="8" Padding="12,6" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Grid.Column="0" FontFamily="Consolas" FontSize="11"
                           Foreground="#8B949E" Text="Готово. Перетягніть слайдер для зміни точності."/>
                <TextBlock Grid.Column="1" FontFamily="Consolas" FontSize="11"
                           Foreground="#6E7681" Text="Чисельні методи в інформатиці · Лаб. №5 · Варіант 9"/>
            </Grid>
        </Border>
    </Grid>
</Window>
