<Window x:Class="LinearSolver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="СЛАР Solver"
        Height="650" Width="950"
        Background="#1E1E2F"
        FontFamily="Segoe UI">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Розв'язання СЛАР"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="Bold"/>

        <!-- Панель -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 15">

            <TextBlock Text="Розмір:" Foreground="White"/>
            <TextBox x:Name="SizeBox" Width="50" Text="3" Margin="5"/>

            <TextBlock Text="Метод:" Foreground="White" Margin="10 0 0 0"/>
            <ComboBox x:Name="MethodBox" Width="150">
                <ComboBoxItem Content="Метод Гауса" IsSelected="True"/>
                <ComboBoxItem Content="LU-розклад"/>
            </ComboBox>

            <Button Content="Створити"
                    Click="CreateMatrix_Click"
                    Margin="10 0"
                    Background="#3A3A5A"
                    Foreground="White"/>

            <Button Content="Розв'язати"
                    Click="Solve_Click"
                    Margin="10 0"
                    Background="#4CAF50"
                    Foreground="White"/>

            <Button Content="Заповнити прикладом"
                    Click="FillExample_Click"
                    Margin="10 0"
                    Background="#2196F3"
                    Foreground="White"/>

        </StackPanel>

        <!-- Вибір варіанту -->
        <ComboBox x:Name="ExampleBox"
                  Grid.Row="2"
                  Margin="0 5"
                  Background="#2A2A40"
                  Foreground="Black"/>

        <TextBlock Grid.Row="2"
                   Margin="0 35 0 5"
                   Text="Останній стовпець — це b"
                   Foreground="#AAAAFF"/>

        <!-- Таблиця -->
        <DataGrid x:Name="MatrixGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="True"
                  HeadersVisibility="All"
                  CanUserAddRows="False"
                  GridLinesVisibility="All"
                  Background="#1A1A2E"
                  RowBackground="#2A2A40"
                  AlternatingRowBackground="#33334D"
                  Foreground="Black"
                  BorderBrush="#555"
                  CellEditEnding="MatrixGrid_CellEditEnding">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#444466"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Style>
            </DataGrid.Resources>
        </DataGrid>

        <!-- Кроки -->
        <TextBox x:Name="StepsBox"
                 Grid.Row="4"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Background="#111122"
                 Foreground="#00FFAA"
                 FontFamily="Consolas"/>

        <!-- Результат -->
        <TextBlock x:Name="ResultText"
                   Grid.Row="5"
                   Foreground="LightGreen"
                   FontSize="16"
                   Margin="0 10"/>
    </Grid>
</Window>